#!/usr/bin/env bash
# pre-command hook: runs before each command step
# Sets up environment variables and tooling required for the build

set -euo pipefail

echo "--- :buildkite: Setting up build environment"

# Ensure required environment variables are present
if [[ -z "${BUILDKITE_BRANCH:-}" ]]; then
  echo "ERROR: BUILDKITE_BRANCH is not set"
  exit 1
fi

# Determine if this is a pull request build
if [[ "${BUILDKITE_PULL_REQUEST:-false}" != "false" ]]; then
  export IS_PULL_REQUEST=true
  echo "Pull Request build detected: #${BUILDKITE_PULL_REQUEST}"
else
  export IS_PULL_REQUEST=false
fi

# Set Go environment
export GOFLAGS="-mod=vendor"
export GONOSUMCHECK="*"
export GOPATH="${HOME}/go"
export PATH="${GOPATH}/bin:${PATH}"

echo "Go version: $(go version)"

# Set Node environment
export NODE_ENV="production"
if [[ -f ".nvmrc" ]]; then
  NODE_VERSION=$(cat .nvmrc)
  echo "Using Node.js version: ${NODE_VERSION}"
fi

# Configure Docker buildx if available
if command -v docker &>/dev/null; then
  if docker buildx version &>/dev/null; then
    echo "--- :docker: Configuring Docker Buildx"
    docker buildx inspect default || docker buildx create --use --name default
  fi
fi

# Set build metadata
export BUILD_DATE=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
export BUILD_COMMIT="${BUILDKITE_COMMIT:-unknown}"
export BUILD_BRANCH="${BUILDKITE_BRANCH:-unknown}"
export BUILD_TAG="${BUILDKITE_TAG:-}"

echo "Build metadata:"
echo "  Date:   ${BUILD_DATE}"
echo "  Commit: ${BUILD_COMMIT}"
echo "  Branch: ${BUILD_BRANCH}"
[[ -n "${BUILD_TAG}" ]] && echo "  Tag:    ${BUILD_TAG}"

# Restore any cached dependencies if cache exists
if [[ -d "${HOME}/.cache/go-build" ]]; then
  echo "Go build cache found at ${HOME}/.cache/go-build"
fi

echo "--- :white_check_mark: Build environment ready"
